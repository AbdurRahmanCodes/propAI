# Backend Environment Variables
# Copy this file to backend/.env and fill in your values

# MongoDB Atlas connection string (example format only)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# Database name
DB_NAME=propai

# JWT secret key (use a long random value)
SECRET_KEY=replace-with-a-secure-random-secret

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Request timing window for dashboard performance stats
PERFORMANCE_WINDOW_SIZE=500
